# ═══════════════════════════════════════════════════════════════════════
# CodeDebt Guardian — Environment Configuration
# Copy this file to .env and fill in your values.
# ═══════════════════════════════════════════════════════════════════════

# ── Application ──────────────────────────────────────────────────────
APP_NAME=CodeDebt Guardian
DEBUG=false
LOG_LEVEL=INFO
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32

# ── Database (PostgreSQL + pgvector) ────────────────────────────────
DATABASE_URL=postgresql+asyncpg://codedebt:codedebt@localhost:5432/codedebt
DATABASE_SYNC_URL=postgresql://codedebt:codedebt@localhost:5432/codedebt

# ── Redis ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── AI Providers (keys managed by AI Gateway — never exposed to clients)
GOOGLE_API_KEY=your-gemini-api-key
GROQ_API_KEY=your-groq-api-key
OPENAI_API_KEY=your-openai-api-key

# ── GitHub Integration ───────────────────────────────────────────────
GITHUB_TOKEN=ghp_your_github_pat
GITHUB_CLIENT_ID=your-github-oauth-client-id
GITHUB_CLIENT_SECRET=your-github-oauth-client-secret
GITHUB_WEBHOOK_SECRET=your-webhook-secret

# ── Stripe Billing ───────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRICE_PRO_MONTHLY=price_xxx
STRIPE_PRICE_ENTERPRISE_MONTHLY=price_yyy

# ── CORS ─────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# ── Business Logic ───────────────────────────────────────────────────
DEV_HOURLY_RATE=85.0
CODEDEBT_MAX_PR_DOLLARS=500.0

# ── Observability ────────────────────────────────────────────────────
OTEL_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=codedebt-guardian
